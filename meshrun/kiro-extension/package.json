{
  "name": "meshrun-kiro",
  "displayName": "MeshRun",
  "description": "Distributed AI inference on compute you already own. Built for Kiro.",
  "version": "0.1.0",
  "publisher": "meshrun",
  "keywords": ["meshrun", "kiro", "distributed-ai", "inference", "mesh"],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "meshrun.submit",
        "title": "MeshRun: Submit Inference Job",
        "icon": "$(play)"
      },
      {
        "command": "meshrun.status",
        "title": "MeshRun: Show Network Status"
      },
      {
        "command": "meshrun.nodes",
        "title": "MeshRun: List Nodes"
      },
      {
        "command": "meshrun.credits",
        "title": "MeshRun: Show Credits"
      },
      {
        "command": "meshrun.join",
        "title": "MeshRun: Join Mesh as Worker"
      },
      {
        "command": "meshrun.leave",
        "title": "MeshRun: Leave Mesh"
      },
      {
        "command": "meshrun.dashboard",
        "title": "MeshRun: Open Dashboard"
      },
      {
        "command": "meshrun.refreshSidebar",
        "title": "MeshRun: Refresh Sidebar",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "meshrun-sidebar",
          "title": "MeshRun",
          "icon": "$(server)"
        }
      ]
    },
    "views": {
      "meshrun-sidebar": [
        {
          "id": "meshrunNodes",
          "name": "Nodes"
        },
        {
          "id": "meshrunJobs",
          "name": "Jobs"
        },
        {
          "id": "meshrunCredits",
          "name": "Credits"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "meshrunNodes",
        "contents": "Welcome to MeshRun — distributed AI on compute you already own.\n\nJoin the mesh to start contributing GPU power and earning credits.\n[Join Mesh](command:meshrun.join)\n[Open Dashboard](command:meshrun.dashboard)",
        "when": "!meshrun.joined"
      },
      {
        "view": "meshrunJobs",
        "contents": "No inference jobs yet.\n\nSubmit your first prompt to see it here.\n[Submit Job](command:meshrun.submit)",
        "when": "!meshrun.joined"
      },
      {
        "view": "meshrunCredits",
        "contents": "Join the mesh to start earning credits.\n[Join Mesh](command:meshrun.join)",
        "when": "!meshrun.joined"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "meshrun.submit",
          "when": "view == meshrunNodes",
          "group": "navigation"
        },
        {
          "command": "meshrun.refreshSidebar",
          "when": "view == meshrunNodes",
          "group": "navigation"
        },
        {
          "command": "meshrun.submit",
          "when": "view == meshrunJobs",
          "group": "navigation"
        },
        {
          "command": "meshrun.refreshSidebar",
          "when": "view == meshrunJobs",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "MeshRun",
      "properties": {
        "meshrun.autoRefresh.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh the MeshRun sidebar at a regular interval."
        },
        "meshrun.autoRefresh.intervalSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "description": "How often (in seconds) to auto-refresh the sidebar. Minimum 5 seconds."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@vscode/vsce": "^2.24.0",
    "typescript": "^5.3.0"
  }
}
